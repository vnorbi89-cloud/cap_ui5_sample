{
  "name": "ui5",
  "version": "0.0.1",
  "description": "An SAP Fiori application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "dependencies": {},
  "devDependencies": {
    "@ui5/cli": "^4.0.33",
    "@sap/ux-ui5-tooling": "1",
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "eslint": "^10",
		"ui5-middleware-livereload": "^3.1.2",
		"ui5-task-zipper": "^3.3.0",
		"ui5-test-runner": "^5.9.1",
		"ui5-tooling-transpile": "^3.9.0"
  },
  "scripts": {
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf",
    "start": "ui5 serve --port 8080 -o index.html",
    "build:cf1": "ui5 build --clean-dest --dest dist && mkdir -p resources && cd dist && zip -r ../dist/ui5.zip *",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateManifestBundle --include-task=generateCachebusterInfo"
		
  }
}
